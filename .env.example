# Signal Engine v1 backend/runtime configuration.
# Copy to .env for local runs. Never commit real secret values.

# Supabase/Postgres session pooler URL. Use port 5432 for GitHub Actions.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres

# Supabase JWT secret for dashboard API auth validation.
SUPABASE_JWT_SECRET=replace-me

# LLM providers.
ANTHROPIC_API_KEY=sk-ant-...
XAI_API_KEY=xai-...
OPENAI_API_KEY=sk-...
DEEPSEEK_API_KEY=sk-...

# News/search enrichment.
EXA_API_KEY=replace-me

# Telegram notifications and bot-triggered GitHub Actions.
TELEGRAM_BOT_TOKEN=replace-me
TELEGRAM_CHAT_ID=replace-me

# GitHub workflow dispatch from API/bot.
GITHUB_TOKEN=ghp_...
GITHUB_REPO=jsonidx/signal_engine_v1

# Optional notification channel.
DISCORD_WEBHOOK_URL=

# Optional production CORS override for FastAPI.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Optional local IBKR gateway / TWS connection for options workflows.
IBKR_HOST=127.0.0.1
IBKR_PORT=4002
IBKR_CLIENT_ID=10
