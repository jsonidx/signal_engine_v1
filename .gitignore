# Virtual environments
venv/
.venv/

# Environment / secrets
.env
*.env

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Data / output files
signals_output/
signal_reports/
*.csv
*.json
# Local cache databases (generated, not committed)
*.db
*.db-shm
*.db-wal

# Logs
logs/

# Cache JSON files (all local, ephemeral — never commit)
fx_cache.json
polymarket_cache.json
congress_cache.json
quant_report_cache.json
data/regime_cache.json
data/sector_cache.json
data/trends_cache.json
data/twits_cache.json
data/dark_pool_latest.json

# Report outputs (generated on demand)
quant_reports/
weekly_reports/

# FINRA raw data cache (large, rebuilt from API)
data/finra_cache/

# Dashboard frontend build artifacts
dashboard/frontend/node_modules/
dashboard/frontend/dist/
# Allow frontend config files (overrides *.json rule above)
!dashboard/frontend/package.json
!dashboard/frontend/package-lock.json
!dashboard/frontend/tsconfig.json
!dashboard/frontend/tsconfig.node.json

# Generated launchd plists (machine-specific, created by setup_schedules.sh)
*.plist

# OS
.DS_Store
