{
  "python.defaultInterpreterPath": "${workspaceFolder}/venv/bin/python",
  "python.testing.pytestEnabled": true,
  "python.testing.unittestEnabled": false,
  "python.testing.pytestArgs": [
    "tests"
  ],
  "editor.formatOnSave": false,
  "files.exclude": {
    "**/__pycache__": true,
    "**/*.pyc": true,
    "venv": true,
    ".venv": true,
    "dashboard/frontend/node_modules": true,
    "dashboard/frontend/dist": true
  },
  "search.exclude": {
    "**/venv": true,
    "**/.venv": true,
    "**/node_modules": true,
    "**/dist": true,
    "**/__pycache__": true,
    "data/finra_cache": true,
    "data/universe_cache": true,
    "signals_output": true,
    "logs": true
  },
  "typescript.tsdk": "dashboard/frontend/node_modules/typescript/lib"
}
