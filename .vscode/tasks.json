{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "verify: local",
      "type": "shell",
      "command": "bash scripts/verify_local.sh",
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "test: backend",
      "type": "shell",
      "command": "pytest",
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "test: frontend",
      "type": "shell",
      "command": "npm test",
      "options": {
        "cwd": "${workspaceFolder}/dashboard/frontend"
      },
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "build: frontend",
      "type": "shell",
      "command": "npm run build",
      "options": {
        "cwd": "${workspaceFolder}/dashboard/frontend"
      },
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "pipeline: skip-ai",
      "type": "shell",
      "command": "bash run_master.sh --skip-ai",
      "problemMatcher": []
    },
    {
      "label": "dashboard: dev",
      "type": "shell",
      "command": "bash start_dashboard.sh",
      "isBackground": true,
      "problemMatcher": []
    }
  ]
}
